{
  "name": "freeroll-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/next/dist/bin/next lint",
    "qa:solo": "node ./node_modules/typescript/bin/tsc -p tsconfig.solo-bug-hunt.json && node ./.codex-solo-bug-hunt/scripts/solo-bug-hunt.js",
    "qa:sandbox": "node ./node_modules/typescript/bin/tsc -p tsconfig.solo-bug-hunt.json && node ./.codex-solo-bug-hunt/scripts/sandbox-generalization-check.js",
    "qa:sandbox:tiers": "node ./node_modules/typescript/bin/tsc -p tsconfig.solo-bug-hunt.json && node ./.codex-solo-bug-hunt/scripts/sandbox-generalization-check.js --counts=100,200,300 --output=docs/SANDBOX_GENERALIZATION_TIERS_REPORT.md",
    "qa:sandbox:tiers:ai": "node ./node_modules/typescript/bin/tsc -p tsconfig.solo-bug-hunt.json && node ./.codex-solo-bug-hunt/scripts/sandbox-generalization-check.js --counts=100,200,300 --with-ai --output=docs/SANDBOX_GENERALIZATION_TIERS_REPORT.md",
    "qa:consequences": "node ./node_modules/typescript/bin/tsc -p tsconfig.solo-bug-hunt.json && node ./.codex-solo-bug-hunt/scripts/sandbox-consequences-demo.js",
    "qa:wtf": "node ./node_modules/typescript/bin/tsc -p tsconfig.solo-bug-hunt.json && node ./.codex-solo-bug-hunt/scripts/sandbox-wtf-analysis.js",
    "qa:wtf:fuzz": "node ./node_modules/typescript/bin/tsc -p tsconfig.solo-bug-hunt.json && node ./.codex-solo-bug-hunt/scripts/sandbox-wtf-fuzz.js --count=300 --seed=1337 --output=docs/SANDBOX_WTF_FUZZ_REPORT.md --json=docs/SANDBOX_WTF_FUZZ_RESULTS.json",
    "qa:world": "node ./node_modules/typescript/bin/tsc -p tsconfig.solo-bug-hunt.json && node scripts/world-audit.js",
    "map:pnj": "node ./node_modules/typescript/bin/tsc -p tsconfig.solo-bug-hunt.json && node scripts/world-npc-map.js && node scripts/world-npc-map-assets.js",
    "map:pnj:assets": "node ./node_modules/typescript/bin/tsc -p tsconfig.solo-bug-hunt.json && node scripts/world-npc-map-assets.js",
    "docs:check": "node scripts/docs-check.js"
  },
  "dependencies": {
    "groq-sdk": "^1.1.1",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "canvas": "^3.2.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "typescript": "^5"
  }
}
